<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="26dp">

    <TextView
        android:id="@+id/sectionTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/section_placeholder_default_title"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
        android:textColor="@color/ch_text_primary"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="@color/ch_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_blue_100"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_placeholder_label"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                android:textColor="@color/ch_text_secondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sectionBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/section_placeholder_default_message"
                android:textColor="@color/ch_text_primary"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
