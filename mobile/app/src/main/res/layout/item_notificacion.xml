<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/ch_space_xs"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/ch_surface_card"
    app:cardCornerRadius="@dimen/ch_radius_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/ch_blue_100"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/ch_space_md">

        <!-- Unread indicator dot -->
        <View
            android:id="@+id/unreadIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/ch_space_sm"
            android:background="@color/ch_primary"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/notificacionTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                    android:textColor="@color/ch_text_primary" />

                <TextView
                    android:id="@+id/notificacionTipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ch_space_xs"
                    android:background="@drawable/bg_estado_badge"
                    android:paddingHorizontal="@dimen/ch_space_sm"
                    android:paddingVertical="4dp"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/notificacionMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ch_space_xs"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                android:textColor="@color/ch_text_secondary" />

            <TextView
                android:id="@+id/notificacionFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ch_space_sm"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                android:textColor="@color/ch_text_secondary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
