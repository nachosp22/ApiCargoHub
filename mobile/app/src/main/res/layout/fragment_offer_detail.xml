<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background"
    android:orientation="vertical">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/offerDetailSwipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/offerDetailContentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/ch_space_md"
                    android:paddingTop="@dimen/ch_space_lg"
                    android:paddingBottom="@dimen/ch_space_md"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/ch_space_md"
                        app:cardBackgroundColor="@color/ch_surface_card"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/ch_space_md">

                            <TextView
                                android:id="@+id/offerDetailTitleText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
                                android:textColor="@color/ch_text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/offerDetailRouteText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_sm"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_primary"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/ch_space_sm"
                        app:cardBackgroundColor="@color/ch_surface_card"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/ch_space_md">

                            <TextView android:id="@+id/offerDetailPickupText" android:layout_width="match_parent" android:layout_height="wrap_content" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />
                            <TextView android:id="@+id/offerDetailDistanceText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />
                            <TextView android:id="@+id/offerDetailPriceText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall" android:textColor="@color/ch_accent_primary" android:textStyle="bold" />
                            <TextView android:id="@+id/offerDetailCargoText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />
                            <TextView android:id="@+id/offerDetailWeightText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />
                            <TextView android:id="@+id/offerDetailVolumeText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />
                            <TextView android:id="@+id/offerDetailDimensionsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />
                            <TextView android:id="@+id/offerDetailVehicleText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ch_space_xs" android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" android:textColor="@color/ch_text_primary" />

                            <TextView
                                android:id="@+id/offerDetailHelperText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_sm"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                                android:textColor="@color/ch_text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:id="@+id/offerDetailLoadingContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:gravity="center"
                    android:text="@string/offer_detail_state_loading_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_text_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:gravity="center"
                    android:text="@string/offer_detail_state_loading_body"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodySmall"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/offerDetailEmptyContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl"
                android:visibility="gone">

                <TextView
                    android:id="@+id/offerDetailEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_state_surface"
                    android:gravity="center"
                    android:padding="@dimen/ch_space_lg"
                    android:text="@string/offer_detail_state_empty_body"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/offerDetailErrorContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/offer_detail_state_error_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_error_text" />

                <TextView
                    android:id="@+id/offerDetailErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:background="@drawable/bg_error_soft"
                    android:gravity="center"
                    android:padding="@dimen/ch_space_md"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_error_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/offerDetailRetryButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/offer_detail_retry_content_description"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:text="@string/retry_button"
                    android:textAllCaps="false" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom CTA bar — pinned outside scroll -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ch_surface_card"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/ch_space_md"
        android:paddingTop="@dimen/ch_space_sm"
        android:paddingBottom="@dimen/ch_space_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/offerAcceptButton"
            style="@style/Widget.ApiCargoHub.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="@string/offer_accept_content_description"
            android:text="@string/offer_accept_action"
            android:textAllCaps="false"
            app:backgroundTint="@color/ch_success" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/offerRejectButton"
            style="@style/Widget.ApiCargoHub.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_xs"
            android:contentDescription="@string/offer_reject_content_description"
            android:text="@string/offer_reject_action"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
