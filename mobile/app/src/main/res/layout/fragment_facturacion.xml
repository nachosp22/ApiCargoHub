<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_primary">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ch_primary">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header resumen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/billing_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <!-- Resumen cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Facturado -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        app:cardBackgroundColor="@color/ch_blue_700"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ch_blue_500"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/billing_card_invoiced"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/resumenFacturado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                tools:text="1.250,00 €" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Pagado -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/spacing_2xs"
                        app:cardBackgroundColor="@color/ch_blue_700"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ch_blue_500"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/billing_card_paid"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/resumenPagado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                tools:text="980,00 €" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Pendiente -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_xs"
                        app:cardBackgroundColor="@color/ch_blue_700"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ch_blue_500"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/billing_card_pending"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/resumenPendiente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                tools:text="270,00 €" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Filtros: chips de período -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/periodoChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    app:singleSelection="true"
                    app:selectionRequired="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemana"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/billing_filter_week"
                        app:chipBackgroundColor="@color/billing_filter_chip_background"
                        app:chipStrokeColor="@color/billing_filter_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"
                        app:rippleColor="@color/ch_primary_container"
                        android:textColor="@color/billing_filter_chip_text" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipMes"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/billing_filter_month"
                        app:chipBackgroundColor="@color/billing_filter_chip_background"
                        app:chipStrokeColor="@color/billing_filter_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"
                        app:rippleColor="@color/ch_primary_container"
                        android:textColor="@color/billing_filter_chip_text" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAnio"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/billing_filter_year"
                        app:chipBackgroundColor="@color/billing_filter_chip_background"
                        app:chipStrokeColor="@color/billing_filter_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"
                        app:rippleColor="@color/ch_primary_container"
                        android:textColor="@color/billing_filter_chip_text" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_home_panel"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_sm">

                <!-- Lista de facturas -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/facturasRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingBottom="@dimen/spacing_md"
                    tools:listitem="@layout/item_factura" />
            </LinearLayout>
        </LinearLayout>

        <!-- Loading -->
        <LinearLayout
            android:id="@+id/loadingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ch_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/billing_loading"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                android:textColor="@color/ch_text_primary" />
        </LinearLayout>

        <!-- Empty -->
        <LinearLayout
            android:id="@+id/emptyContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ch_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_3xl"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_state_surface"
                android:padding="@dimen/spacing_md"
                android:text="@string/billing_empty"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_text_secondary"
                android:gravity="center" />
        </LinearLayout>

        <!-- Error -->
        <LinearLayout
            android:id="@+id/errorContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ch_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_3xl"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/offer_list_state_error_title"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                android:textColor="@color/ch_error_text" />

            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_error_soft"
                android:gravity="center"
                android:padding="@dimen/spacing_md"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                android:textColor="@color/ch_error_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryButton"
                style="@style/Widget.ApiCargoHub.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/retry_button"
                android:textAllCaps="false" />
        </LinearLayout>

    </FrameLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
