<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ch_surface"
    android:orientation="vertical"
    android:padding="@dimen/ch_space_lg">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/ch_outline" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_sm"
        android:gravity="center"
        android:text="@string/pause_reason_title"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
        android:textColor="@color/ch_text_primary"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_xs"
        android:gravity="center"
        android:text="@string/pause_reason_subtitle"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
        android:textColor="@color/ch_text_secondary" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pauseReasonList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_md"
        android:overScrollMode="never" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/pauseNoteLayout"
        style="@style/Widget.ApiCargoHub.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_sm"
        android:hint="@string/pause_note_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/pauseNoteInput"
            style="@style/Widget.ApiCargoHub.TextInputEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:maxLines="3" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/pauseReasonCancelButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/ch_space_sm"
        android:text="@string/pause_reason_cancel_action" />

</LinearLayout>
