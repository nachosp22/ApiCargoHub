<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/ch_space_md"
        android:paddingTop="@dimen/ch_space_lg"
        android:paddingBottom="@dimen/ch_space_md">

        <!-- Profile summary card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileSectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ch_surface_card"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="2dp"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_profile_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.SectionLabel"
                    android:textColor="@color/ch_text_secondary" />

                <TextView
                    android:id="@+id/profileNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:text="@string/home_profile_name_placeholder"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profileEmailText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:text="@string/home_profile_email_placeholder"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_text_secondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/profileRoleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_login_logo_placeholder"
                        android:gravity="center"
                        android:padding="@dimen/ch_space_sm"
                        android:text="@string/home_profile_role_default"
                        android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileConductorIdText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/ch_space_sm"
                        android:layout_weight="1"
                        android:background="@color/ch_blue_50"
                        android:gravity="center"
                        android:padding="@dimen/ch_space_sm"
                        android:text="@string/home_profile_id_unknown"
                        android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                        android:textColor="@color/ch_blue_700"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/profileDetailHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:text="@string/home_profile_hint"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick actions -->
        <LinearLayout
            android:id="@+id/quickActionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_md"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_quick_access_title"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.SectionLabel"
                android:textColor="@color/ch_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickCurrentTripCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ch_space_sm"
                android:paddingVertical="@dimen/ch_space_md"
                android:text="@string/home_quick_current_trip"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/ch_success"
                app:cornerRadius="@dimen/ch_radius_md" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickUpcomingTripsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ch_space_xs"
                android:paddingVertical="@dimen/ch_space_md"
                android:text="@string/home_quick_upcoming_trips"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/ch_warning"
                app:cornerRadius="@dimen/ch_radius_md" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickNewIncidentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ch_space_xs"
                android:paddingVertical="@dimen/ch_space_md"
                android:text="@string/home_quick_new_incident"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/ch_error"
                app:cornerRadius="@dimen/ch_radius_md" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
