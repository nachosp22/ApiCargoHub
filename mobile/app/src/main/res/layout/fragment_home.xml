<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/homeContentColumn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.95">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileSectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ch_surface_card"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ch_blue_100"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_profile_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_text_secondary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profileNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/home_profile_name_placeholder"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profileEmailText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/home_profile_email_placeholder"
                    android:textColor="@color/ch_text_secondary"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/profileRoleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_login_logo_placeholder"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="@string/home_profile_role_default"
                        android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileConductorIdText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@color/ch_blue_50"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="@string/home_profile_id_unknown"
                        android:textColor="@color/ch_blue_700"
                        android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/profileDetailHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/home_profile_hint"
                    android:textColor="@color/ch_text_secondary"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/quickActionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_quick_access_title"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                android:textColor="@color/ch_text_secondary"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickCurrentTripCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/home_quick_current_trip"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/ch_success"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickUpcomingTripsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/home_quick_upcoming_trips"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/ch_warning"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickNewIncidentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/home_quick_new_incident"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/ch_error"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
