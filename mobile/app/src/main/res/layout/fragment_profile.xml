<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_primary"
    android:orientation="vertical">

    <!-- Header azul -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.34">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.24"
            android:scaleType="centerCrop"
            android:src="@drawable/login_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileAvatarImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_nav_profile"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.ApiCargoHub.Circle"
                    app:strokeColor="@color/white"
                    app:strokeWidth="3dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/profileAvatarEditFab"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:contentDescription="@string/profile_photo_change"
                    android:src="@android:drawable/ic_menu_camera"
                    app:backgroundTint="@color/ch_blue_700"
                    app:elevation="4dp"
                    app:fabCustomSize="36dp"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <TextView
                android:id="@+id/profileNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileEmailTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/profileIdTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_state_chip"
                android:backgroundTint="#1A237E"
                android:paddingHorizontal="14dp"
                android:paddingVertical="2dp"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/profileLoadingProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- Panel blanco -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.66"
        android:background="@drawable/bg_home_panel"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Sección Datos personales -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/ch_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Datos personales"
                        android:textColor="@color/ch_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/ch_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E8EAF6"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Nombre y Apellidos en 2 columnas -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/profileNombreLayout"
                                style="@style/Widget.ApiCargoHub.TextInputLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Nombre">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileNombreInput"
                                    style="@style/Widget.ApiCargoHub.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textPersonName" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <Space
                                android:layout_width="12dp"
                                android:layout_height="match_parent" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/profileApellidosLayout"
                                style="@style/Widget.ApiCargoHub.TextInputLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Apellidos">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileApellidosInput"
                                    style="@style/Widget.ApiCargoHub.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textPersonName" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/profileDniLayout"
                            style="@style/Widget.ApiCargoHub.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="DNI">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profileDniInput"
                                style="@style/Widget.ApiCargoHub.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/profileEmailLayout"
                            style="@style/Widget.ApiCargoHub.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Correo electrónico">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profileEmailInput"
                                style="@style/Widget.ApiCargoHub.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"
                                android:enabled="false" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Teléfono y Ciudad en 2 columnas -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/profileTelefonoLayout"
                                style="@style/Widget.ApiCargoHub.TextInputLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Teléfono">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileTelefonoInput"
                                    style="@style/Widget.ApiCargoHub.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="phone" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <Space
                                android:layout_width="12dp"
                                android:layout_height="match_parent" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/profileCiudadLayout"
                                style="@style/Widget.ApiCargoHub.TextInputLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Ciudad base">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileCiudadInput"
                                    style="@style/Widget.ApiCargoHub.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textCapWords" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/profileRadioAccionKmLayout"
                            style="@style/Widget.ApiCargoHub.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Radio de acción (km)">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profileRadioAccionKmInput"
                                style="@style/Widget.ApiCargoHub.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/profileVehiclesButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/vehicle_my_vehicles_title"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_menu_directions" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/profileDeactivateButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/profile_deactivate_account"
                    android:textAllCaps="false"
                    android:textColor="@color/ch_error"
                    app:strokeColor="@color/ch_error_soft" />
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/profileSaveChangesButton"
            style="@style/Widget.ApiCargoHub.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_save_changes"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
