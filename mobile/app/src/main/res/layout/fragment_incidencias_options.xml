<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_primary"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:alpha="0.24"
            android:scaleType="centerCrop"
            android:src="@drawable/login_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ch_space_sm"
            android:paddingTop="12dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_menu_section_incidents"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_section_panel"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNuevaIncidencia"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="@dimen/ch_space_sm"
            android:backgroundTint="@color/ch_error"
            android:text="@string/home_menu_section_new_incident"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radius_md" />
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/incidenciasTabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@color/ch_surface"
            app:tabBackground="@color/ch_surface"
            app:tabIndicatorColor="@color/ch_primary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabSelectedTextColor="@color/ch_primary"
            app:tabTextAppearance="@style/TextAppearance.ApiCargoHub.LabelLarge"
            app:tabTextColor="@color/ch_text_secondary">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/incidencias_tab_activas" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/incidencias_tab_resueltas" />
        </com.google.android.material.tabs.TabLayout>

        <FrameLayout
            android:id="@+id/incidenciasContentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

</LinearLayout>
