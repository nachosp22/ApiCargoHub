<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_surface"
    android:orientation="vertical"
    android:weightSum="1"
    android:paddingHorizontal="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_lg"
    android:paddingBottom="@dimen/spacing_md">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_menu_section_incidents"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
        android:textColor="@color/ch_text_primary"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:text="@string/section_options_hint"
        android:textColor="@color/ch_text_secondary"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/incidenciaNewCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/ch_error_soft"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_error"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="80dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_menu_section_new_incident"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_error_text"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/incidenciaActiveCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/ch_warning_soft"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_warning"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="80dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_menu_section_active_incidents"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_warning_text"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/incidenciaHistoryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/ch_blue_50"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_blue_200"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="80dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_menu_section_incident_history"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_blue_700"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
