<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_surface"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/ch_space_md"
    android:paddingTop="@dimen/ch_space_lg"
    android:paddingBottom="@dimen/ch_space_md">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_menu_section_ports"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
        android:textColor="@color/ch_text_primary"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_xs"
        android:text="@string/section_options_hint"
        android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
        android:textColor="@color/ch_text_secondary" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/porteActiveCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_md"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/ch_success_soft"
        app:cardCornerRadius="@dimen/ch_radius_md"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_success"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="72dp"
            android:paddingHorizontal="@dimen/ch_space_md"
            android:paddingVertical="@dimen/ch_space_md"
            android:text="@string/home_menu_section_trip_active"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
            android:textColor="@color/ch_success_text"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/porteUpcomingCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_sm"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/ch_warning_soft"
        app:cardCornerRadius="@dimen/ch_radius_md"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_warning"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="72dp"
            android:paddingHorizontal="@dimen/ch_space_md"
            android:paddingVertical="@dimen/ch_space_md"
            android:text="@string/home_menu_section_trip_upcoming"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
            android:textColor="@color/ch_warning_text"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/porteHistoryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ch_space_sm"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/ch_blue_50"
        app:cardCornerRadius="@dimen/ch_radius_md"
        app:cardElevation="0dp"
        app:strokeColor="@color/ch_blue_200"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="72dp"
            android:paddingHorizontal="@dimen/ch_space_md"
            android:paddingVertical="@dimen/ch_space_md"
            android:text="@string/home_menu_section_trip_history"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
            android:textColor="@color/ch_blue_700"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
