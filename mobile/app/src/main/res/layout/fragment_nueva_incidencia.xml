<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/ch_space_md"
        android:paddingTop="@dimen/ch_space_lg"
        android:paddingBottom="@dimen/ch_space_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offer_section_label"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.SectionLabel"
            android:textColor="@color/ch_text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_xs"
            android:text="@string/home_menu_section_new_incident"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
            android:textColor="@color/ch_text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_xs"
            android:text="@string/incidencia_new_subtitle"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
            android:textColor="@color/ch_text_secondary" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/noPortesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_md"
            android:visibility="gone"
            app:cardBackgroundColor="@color/ch_warning_soft"
            app:cardCornerRadius="@dimen/ch_radius_md"
            app:cardElevation="0dp"
            app:strokeColor="@color/ch_warning"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/ch_space_md"
                android:text="@string/incidencia_no_portes"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                android:textColor="@color/ch_warning_text" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_md"
            app:cardBackgroundColor="@color/ch_surface_card"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="2dp"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/incidencia_form_section"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_2xs"
                    android:text="@string/incidencia_form_subtitle"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodySmall"
                    android:textColor="@color/ch_text_secondary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/porteInputLayout"
                    style="@style/Widget.ApiCargoHub.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:hint="@string/incidencia_porte_label">

                    <Spinner
                        android:id="@+id/porteSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="52dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tituloInputLayout"
                    style="@style/Widget.ApiCargoHub.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:hint="@string/incidencia_titulo_label"
                    app:counterEnabled="true"
                    app:counterMaxLength="150"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tituloInput"
                        style="@style/Widget.ApiCargoHub.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:maxLength="150" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/descripcionInputLayout"
                    style="@style/Widget.ApiCargoHub.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:hint="@string/incidencia_descripcion_label"
                    app:counterEnabled="true"
                    app:counterMaxLength="4000"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/descripcionInput"
                        style="@style/Widget.ApiCargoHub.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLength="4000"
                        android:minLines="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/severidadInputLayout"
                        style="@style/Widget.ApiCargoHub.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/incidencia_severidad_label">

                        <Spinner
                            android:id="@+id/severidadSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="52dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="@dimen/ch_space_sm"
                        android:layout_height="match_parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/prioridadInputLayout"
                        style="@style/Widget.ApiCargoHub.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/incidencia_prioridad_label">

                        <Spinner
                            android:id="@+id/prioridadSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="52dp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/loadingProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/ch_space_xl"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/submitButton"
            style="@style/Widget.ApiCargoHub.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_xl"
            android:text="@string/incidencia_submit_button"
            android:textAllCaps="false"
            app:backgroundTint="@color/ch_error" />
    </LinearLayout>
</ScrollView>
