<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_2xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/stats_subtitle"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_secondary" />

                <!-- KPI cards row 1: Completados | Ingreso | Media -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Portes completados -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        app:cardBackgroundColor="@color/ch_primary_container"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_kpi_completed"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/ch_on_primary_container" />

                            <TextView
                                android:id="@+id/kpiPortesCompletados"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
                                android:textColor="@color/ch_on_primary_container"
                                android:textStyle="bold"
                                tools:text="42" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Ingreso total -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/spacing_2xs"
                        app:cardBackgroundColor="@color/ch_success_soft"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_kpi_income"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/ch_success_text" />

                            <TextView
                                android:id="@+id/kpiIngresoTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_success_text"
                                android:textStyle="bold"
                                tools:text="8.450 €" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Media por porte -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_xs"
                        app:cardBackgroundColor="@color/ch_surface_alt"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_kpi_avg"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/ch_text_secondary" />

                            <TextView
                                android:id="@+id/kpiMediaPorPorte"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_text_primary"
                                android:textStyle="bold"
                                tools:text="201 €" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- KPI row 2: Km recorridos | En curso -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Km recorridos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_2xs"
                        app:cardBackgroundColor="@color/ch_surface_card"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ch_outline"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_kpi_km"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/ch_text_secondary" />

                            <TextView
                                android:id="@+id/kpiKmRecorridos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_primary"
                                android:textStyle="bold"
                                tools:text="3.240 km" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- En curso -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_2xs"
                        app:cardBackgroundColor="@color/ch_warning_soft"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_kpi_in_progress"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                                android:textColor="@color/ch_warning_text" />

                            <TextView
                                android:id="@+id/kpiPortesEnCurso"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_2xs"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_warning_text"
                                android:textStyle="bold"
                                tools:text="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Ingresos por mes — bar chart -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:text="@string/stats_chart_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/ch_surface_card"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ch_outline"
                    app:strokeWidth="1dp">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/chartContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="200dp"
                            android:gravity="bottom"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_md" />
                    </HorizontalScrollView>
                </com.google.android.material.card.MaterialCardView>

                <!-- Portes por estado -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:text="@string/stats_states_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/estadosChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm" />
            </LinearLayout>
        </ScrollView>

        <!-- Loading -->
        <LinearLayout
            android:id="@+id/loadingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ch_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/stats_loading"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                android:textColor="@color/ch_text_primary" />
        </LinearLayout>

        <!-- Error -->
        <LinearLayout
            android:id="@+id/errorContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ch_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_3xl"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/offer_list_state_error_title"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                android:textColor="@color/ch_error_text" />

            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_error_soft"
                android:gravity="center"
                android:padding="@dimen/spacing_md"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                android:textColor="@color/ch_error_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryButton"
                style="@style/Widget.ApiCargoHub.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/retry_button"
                android:textAllCaps="false" />
        </LinearLayout>

    </FrameLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
