<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Slim top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_xs"
            android:paddingBottom="@dimen/spacing_sm">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_brand"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
                android:textColor="@color/ch_primary"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/homeMenuButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/home_menu_content_description"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/ic_menu_three_lines"
                app:tint="@color/ch_on_surface" />
        </LinearLayout>

        <!-- Full-bleed content area -->
        <FrameLayout
            android:id="@+id/contentSurfaceCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:id="@+id/contentFragmentContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </LinearLayout>

    <!-- Drawer panel -->
    <LinearLayout
        android:layout_width="312dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/ch_surface"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_2xl"
            android:layout_marginEnd="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="@string/home_menu_section_title"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelLarge"
            android:textColor="@color/ch_on_surface_variant"
            android:textStyle="bold" />

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navigationView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/ch_surface"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingBottom="@dimen/spacing_xs"
            app:itemHorizontalPadding="@dimen/spacing_md"
            app:itemVerticalPadding="@dimen/spacing_sm"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:menu="@menu/main_drawer_menu" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawerLogoutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="@string/home_menu_logout"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/ch_error"
            app:cornerRadius="@dimen/radius_md"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/spacing_xs" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
