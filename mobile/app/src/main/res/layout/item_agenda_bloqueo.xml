<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/ch_space_xs"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/ch_surface_card"
    app:cardCornerRadius="@dimen/ch_radius_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/ch_blue_100"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/ch_space_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/agendaItemTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/agendaItemTypeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/ch_space_xs"
                android:background="@drawable/bg_state_chip"
                android:backgroundTint="@color/ch_blue_100"
                android:paddingStart="@dimen/ch_space_sm"
                android:paddingTop="4dp"
                android:paddingEnd="@dimen/ch_space_sm"
                android:paddingBottom="4dp"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                android:textColor="@color/ch_blue_700"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/agendaItemRangeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_xs"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
            android:textColor="@color/ch_text_secondary" />

        <!-- Delete button hidden — progressive disclosure via long-press or detail -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/agendaItemDeleteButton"
            style="@style/Widget.ApiCargoHub.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_sm"
            android:text="@string/agenda_delete_action"
            android:textAllCaps="false"
            android:textColor="@color/ch_error"
            android:visibility="gone"
            app:strokeColor="@color/ch_error_soft" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
