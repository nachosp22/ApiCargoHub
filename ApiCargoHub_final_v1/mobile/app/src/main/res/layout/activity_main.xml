<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Slim top bar -->
    <LinearLayout
        android:id="@+id/topBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingTop="18dp"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/homeLogo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_cargohub_logo_brand" />

        <TextView
            android:id="@+id/homeBrandText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/home_brand"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
            android:textColor="@color/ch_primary"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/homeMenuButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_logout_square"
            android:contentDescription="@string/home_menu_logout"
            android:padding="8dp"
            android:src="@drawable/ic_logout"
            app:tint="@color/white" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ch_outline" />

    <TextView
        android:id="@+id/offlineBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ch_warning"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="@string/offline_banner"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/contentSurfaceCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/contentFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>
</LinearLayout>
