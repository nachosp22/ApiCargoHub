<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_primary"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:alpha="0.24"
            android:scaleType="centerCrop"
            android:src="@drawable/login_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ch_space_sm"
            android:paddingTop="12dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_menu_section_ports"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_section_panel"
        android:orientation="vertical"
        android:paddingTop="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ch_space_sm"
            android:paddingBottom="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/portesFilterToggleButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/ch_primary"
                android:text="@string/portes_filters"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/portesTabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/ch_surface"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/ch_primary"
            app:tabMode="fixed"
            app:tabRippleColor="@color/ch_primary_container"
            app:tabSelectedTextColor="@color/ch_primary"
            app:tabTextColor="@color/ch_on_surface_variant" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/portesViewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

</LinearLayout>
