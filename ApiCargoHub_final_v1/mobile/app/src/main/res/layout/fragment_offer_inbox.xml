<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_primary"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:alpha="0.24"
            android:scaleType="centerCrop"
            android:src="@drawable/login_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ch_space_sm"
            android:paddingTop="12dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_menu_section_offers"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_section_panel"
        android:orientation="vertical"
        android:paddingTop="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ch_space_sm"
            android:paddingBottom="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/offerFilterToggleButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@color/ch_primary"
            android:text="@string/portes_filters"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/offerSwipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/offerLoadingContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:gravity="center"
                    android:text="@string/offer_list_state_loading_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_text_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:gravity="center"
                    android:text="@string/offer_list_state_loading_body"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodySmall"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/offerEmptyContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl"
                android:visibility="gone">

                <TextView
                    android:id="@+id/offerEmptyMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_state_surface"
                    android:gravity="center"
                    android:padding="@dimen/ch_space_lg"
                    android:text="@string/offer_list_empty_all"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/offerErrorContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/offer_list_state_error_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_error_text" />

                <TextView
                    android:id="@+id/offerErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:background="@drawable/bg_error_soft"
                    android:gravity="center"
                    android:padding="@dimen/ch_space_md"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_error_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/offerRetryButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/offer_retry_content_description"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:text="@string/retry_button"
                    android:textAllCaps="false" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/offerRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/ch_space_md"
                android:paddingBottom="@dimen/ch_space_sm"
                android:visibility="gone" />
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>
</LinearLayout>
