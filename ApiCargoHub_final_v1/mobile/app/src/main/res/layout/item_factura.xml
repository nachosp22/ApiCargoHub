<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/ch_surface_card"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/ch_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Row 1: Nº factura + estado chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/facturaNumero"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_text_primary"
                android:textStyle="bold"
                tools:text="F-2026-0042" />

            <TextView
                android:id="@+id/facturaEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:background="@drawable/bg_estado_badge"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="4dp"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelSmall"
                android:textStyle="bold"
                tools:text="PAGADA" />
        </LinearLayout>

        <!-- Row 2: Fecha + importe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/facturaFecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                android:textColor="@color/ch_text_secondary"
                tools:text="15/04/2026" />

            <TextView
                android:id="@+id/facturaTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                android:textColor="@color/ch_primary_dark"
                android:textStyle="bold"
                tools:text="242,00 €" />
        </LinearLayout>

        <!-- Row 3: Detalle expandible (hidden by default) -->
        <LinearLayout
            android:id="@+id/facturaDetalleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ch_outline" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/billing_detail_base"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_secondary" />

                <TextView
                    android:id="@+id/facturaBase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_primary"
                    tools:text="200,00 €" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xs"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/billing_detail_iva"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_secondary" />

                <TextView
                    android:id="@+id/facturaIva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_primary"
                    tools:text="42,00 €" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xs"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/billing_detail_porte"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_text_secondary" />

                <TextView
                    android:id="@+id/facturaPorteId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                    android:textColor="@color/ch_primary"
                    tools:text="Porte #12" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
