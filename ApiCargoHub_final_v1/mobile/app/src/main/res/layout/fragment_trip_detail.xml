<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/tripDetailSwipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:id="@+id/tripDetailScrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/tripDetailContentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/ch_space_md"
                    android:paddingTop="@dimen/ch_space_sm"
                    android:paddingBottom="@dimen/ch_space_md"
                    android:visibility="gone">

                    <!-- Header card: title + state chip + price -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/ch_space_sm"
                        app:cardBackgroundColor="@color/ch_surface_card"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/ch_space_md">

                            <TextView
                                android:id="@+id/tripDetailTitleText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleLarge"
                                android:textColor="@color/ch_text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tripDetailStateText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_xs"
                                android:background="@drawable/bg_state_chip"
                                android:backgroundTint="@color/ch_success_soft"
                                android:paddingStart="@dimen/ch_space_sm"
                                android:paddingTop="6dp"
                                android:paddingEnd="@dimen/ch_space_sm"
                                android:paddingBottom="6dp"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.LabelMedium"
                                android:textColor="@color/ch_success_text"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tripDetailPriceText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_sm"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_accent_primary"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Route & cargo details -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/ch_space_sm"
                        app:cardBackgroundColor="@color/ch_surface_card"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/ch_space_md">

                            <TextView
                                android:id="@+id/tripDetailScheduleText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                                android:textColor="@color/ch_text_secondary" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="@dimen/ch_space_sm"
                                android:background="@color/ch_surface_alt" />

                            <TextView
                                android:id="@+id/tripDetailCargoText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                                android:textColor="@color/ch_text_primary" />

                            <TextView
                                android:id="@+id/tripDetailActionHintText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_sm"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                                android:textColor="@color/ch_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Fotos button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tripOpenFotosButton"
                        style="@style/Widget.ApiCargoHub.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/ch_space_sm"
                        android:text="📷 Fotos"
                        android:textAllCaps="false"
                        app:icon="@drawable/ic_photo_placeholder"
                        app:iconGravity="textStart" />

                    <!-- Incidents section -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/ch_space_sm"
                        app:cardBackgroundColor="@color/ch_surface_card"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/ch_space_md">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/trip_incidents_card_title"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                                android:textColor="@color/ch_text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tripIncidentsEmptyText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_xs"
                                android:text="@string/trip_incidents_empty"
                                android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyMedium"
                                android:textColor="@color/ch_text_secondary" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/tripIncidentsRecyclerView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_xs"
                                android:nestedScrollingEnabled="false"
                                android:visibility="gone" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/tripReportIncidentButton"
                                style="@style/Widget.Material3.Button"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ch_space_sm"
                                android:backgroundTint="@color/ch_error"
                                android:text="@string/trip_report_incident_action"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:id="@+id/tripDetailLoadingContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:gravity="center"
                    android:text="@string/trip_detail_state_loading_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_text_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:gravity="center"
                    android:text="@string/trip_detail_state_loading_body"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodySmall"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tripDetailEmptyContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tripDetailEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_state_surface"
                    android:gravity="center"
                    android:padding="@dimen/ch_space_lg"
                    android:text="@string/trip_detail_state_empty_body"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tripDetailErrorContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_xl"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/trip_detail_state_error_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleSmall"
                    android:textColor="@color/ch_error_text" />

                <TextView
                    android:id="@+id/tripDetailErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_xs"
                    android:background="@drawable/bg_error_soft"
                    android:gravity="center"
                    android:padding="@dimen/ch_space_md"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
                    android:textColor="@color/ch_error_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/tripDetailRetryButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:text="@string/retry_button"
                    android:textAllCaps="false" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom CTA bar — pinned outside scroll -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ch_surface_card"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/ch_space_md"
        android:paddingTop="@dimen/ch_space_sm"
        android:paddingBottom="@dimen/ch_space_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tripPrimaryActionButton"
            style="@style/Widget.ApiCargoHub.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tripSecondaryActionButton"
            style="@style/Widget.ApiCargoHub.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_xs"
            android:textAllCaps="false"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
