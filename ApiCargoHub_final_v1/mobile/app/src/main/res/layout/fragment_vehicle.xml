<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_primary"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:alpha="0.24"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/login_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ch_space_sm"
            android:paddingTop="12dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_menu_section_vehicle"
                android:textAppearance="@style/TextAppearance.ApiCargoHub.HeadlineLarge"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/ch_surface"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ch_surface"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/ch_space_sm"
        android:paddingTop="@dimen/ch_space_sm"
        android:paddingBottom="@dimen/ch_space_md">

        <!-- Vehicle form -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/vehicleFormCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="2dp"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/vehicle_form_title"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/vehicleMatriculaLayout"
                    style="@style/Widget.ApiCargoHub.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:hint="@string/vehicle_matricula_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/vehicleMatriculaInput"
                        style="@style/Widget.ApiCargoHub.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/vehicleMarcaLayout"
                    style="@style/Widget.ApiCargoHub.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:hint="@string/vehicle_marca_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/vehicleMarcaInput"
                        style="@style/Widget.ApiCargoHub.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/vehicleModeloLayout"
                    style="@style/Widget.ApiCargoHub.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:hint="@string/vehicle_modelo_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/vehicleModeloInput"
                        style="@style/Widget.ApiCargoHub.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <Spinner
                    android:id="@+id/vehicleTipoSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:background="@drawable/bg_vehicle_spinner"
                    android:minHeight="56dp"
                    android:paddingHorizontal="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.ApiCargoHub.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/vehicle_capacidad_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/vehicleCapacidadInput"
                            style="@style/Widget.ApiCargoHub.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="@dimen/ch_space_sm"
                        android:layout_height="match_parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.ApiCargoHub.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/vehicle_largo_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/vehicleLargoInput"
                            style="@style/Widget.ApiCargoHub.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.ApiCargoHub.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/vehicle_ancho_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/vehicleAnchoInput"
                            style="@style/Widget.ApiCargoHub.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="@dimen/ch_space_sm"
                        android:layout_height="match_parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.ApiCargoHub.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/vehicle_alto_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/vehicleAltoInput"
                            style="@style/Widget.ApiCargoHub.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/vehicleSaveButton"
                        style="@style/Widget.ApiCargoHub.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:minWidth="0dp"
                        android:minHeight="48dp"
                        android:text="@string/vehicle_save_action"
                        android:textAllCaps="false" />

                    <Space
                        android:layout_width="@dimen/ch_space_sm"
                        android:layout_height="match_parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/vehicleRefreshButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary_gray_soft"
                        android:backgroundTint="@null"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:minWidth="0dp"
                        android:minHeight="48dp"
                        android:text="@string/vehicle_clear_form_action"
                        android:textAllCaps="false"
                        android:textColor="@color/ch_text_primary" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/vehicleCancelButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:text="@string/vehicle_cancel_edit_action"
                    android:textAllCaps="false"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/vehicleNewButton"
            style="@style/Widget.ApiCargoHub.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/ch_space_md"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:minHeight="48dp"
            android:text="@string/vehicle_new_action"
            android:textAllCaps="false" />

        <ProgressBar
            android:id="@+id/vehicleLoadingProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/ch_space_lg" />

        <TextView
            android:id="@+id/vehicleEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_md"
            android:text="@string/vehicle_empty"
            android:textAppearance="@style/TextAppearance.ApiCargoHub.BodyLarge"
            android:textColor="@color/ch_text_secondary"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/vehicleRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ch_space_md"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
    </ScrollView>
</LinearLayout>
