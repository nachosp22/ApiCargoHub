<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ch_background">

    <org.osmdroid.views.MapView
        android:id="@+id/trackingMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/trackingStatsCard" />

    <LinearLayout
        android:id="@+id/trackingSetupOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ch_overlay_medium"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ch_surface_card"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="2dp"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ch_space_lg">

                <ProgressBar
                    android:id="@+id/trackingLoadingProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="@dimen/ch_space_md"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/trackingStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/tracking_status_idle"
                    android:textAppearance="@style/TextAppearance.ApiCargoHub.TitleMedium"
                    android:textColor="@color/ch_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trackingGoHomeButton"
                    style="@style/Widget.ApiCargoHub.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_md"
                    android:text="Ir al inicio"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trackingGoPortesButton"
                    style="@style/Widget.ApiCargoHub.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ch_space_sm"
                    android:text="Ir a portes"
                    android:textAllCaps="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/drivingModeFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:contentDescription="@string/driving_mode_enter"
        android:visibility="gone"
        app:backgroundTint="@color/ch_primary"
        app:fabSize="mini"
        app:maxImageSize="24dp"
        app:srcCompat="@drawable/ic_driving_mode"
        app:tint="@color/white" />

    <!-- ══ Driving mode overlay: TOP bar ══ -->
    <FrameLayout
        android:id="@+id/drivingOverlayTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/ch_overlay_strong"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_3xl"
        android:paddingBottom="@dimen/spacing_md"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Speed big -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/drivingSpeedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/driving_speed_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:text="@string/driving_mode_speed_unit"
                    android:textColor="#B0FFFFFF"
                    android:textSize="@dimen/driving_eta_text_size" />
            </LinearLayout>

            <!-- ETA + status -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/drivingEtaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:-- · -- min"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/driving_eta_text_size" />

                <TextView
                    android:id="@+id/drivingStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2xs"
                    android:background="@color/ch_success_chip_tint"
                    android:paddingHorizontal="@dimen/spacing_xs"
                    android:paddingVertical="2dp"
                    android:text="@string/driving_mode_on_route"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/ch_text_size_label"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ══ Driving mode overlay: BOTTOM bar ══ -->
    <FrameLayout
        android:id="@+id/drivingOverlayBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/ch_overlay_strong"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingVertical="@dimen/spacing_md"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Distance remaining -->
            <TextView
                android:id="@+id/drivingDistanceValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-- km"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/driving_distance_text_size"
                android:textStyle="bold" />

            <!-- Mini play/pause -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/drivingPlayPauseFab"
                android:layout_width="@dimen/driving_fab_mini_size"
                android:layout_height="@dimen/driving_fab_mini_size"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:contentDescription="@string/tracking_play_pause_description"
                app:backgroundTint="@color/ch_success"
                app:fabSize="mini"
                app:maxImageSize="20dp"
                app:srcCompat="@android:drawable/ic_media_pause"
                app:tint="@color/white" />

            <!-- Exit driving mode -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/drivingExitFab"
                android:layout_width="@dimen/driving_fab_mini_size"
                android:layout_height="@dimen/driving_fab_mini_size"
                android:contentDescription="@string/driving_mode_exit"
                app:backgroundTint="@color/ch_surface"
                app:fabSize="mini"
                app:maxImageSize="20dp"
                app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/ch_text_primary" />
        </LinearLayout>
    </FrameLayout>

    <!-- Status chip - top of screen over map -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/trackingStatusChipCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/ch_space_lg"
        android:visibility="gone"
        app:cardBackgroundColor="@color/ch_success"
        app:cardCornerRadius="@dimen/radius_xl"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/trackingStatusChipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs"
            android:text="@string/tracking_status_on_route"
            android:textColor="@color/white"
            android:textSize="@dimen/ch_text_size_label"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/trackingSessionMetaCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/trackingStatusChipCard"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/ch_space_xs"
        android:maxWidth="@dimen/tracking_session_meta_card_max_width"
        android:visibility="gone"
        app:cardBackgroundColor="@color/ch_surface_card"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_2xs">

            <TextView
                android:id="@+id/trackingSessionStatusValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/ch_text_primary"
                android:textSize="@dimen/ch_text_size_label"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trackingSessionPhaseValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/ch_text_secondary"
                android:textSize="@dimen/ch_text_size_label" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Play/Pause FAB - between map and stats -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/trackingPlayPauseFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/trackingStatsCard"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:contentDescription="@string/tracking_play_pause_description"
        android:visibility="gone"
        app:backgroundTint="@color/ch_success"
        app:fabSize="normal"
        app:maxImageSize="28dp"
        app:srcCompat="@android:drawable/ic_media_pause"
        app:tint="@color/white" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/trackingRecenterFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/trackingStatsCard"
        android:layout_alignParentStart="true"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:contentDescription="@string/tracking_recenter_action"
        android:visibility="gone"
        app:backgroundTint="@color/ch_surface"
        app:fabSize="mini"
        app:maxImageSize="20dp"
        app:srcCompat="@android:drawable/ic_menu_mylocation"
        app:tint="@color/ch_primary" />

    <!-- Info FAB - top left corner over map (above recenter) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/trackingInfoFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginStart="@dimen/spacing_md"
        android:contentDescription="@string/tracking_active_trip_details_content_description"
        android:visibility="gone"
        app:backgroundTint="@color/ch_surface"
        app:fabSize="mini"
        app:maxImageSize="22dp"
        app:srcCompat="@android:drawable/ic_menu_info_details"
        app:tint="@color/ch_primary" />

    <!-- Stats panel anchored below map (no overlap) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/trackingStatsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:visibility="gone"
        app:cardBackgroundColor="@color/ch_surface_card"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="4dp"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

            <!-- ETA row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/tracking_map_eta_label"
                    android:textColor="@color/ch_on_surface_variant"
                    android:textSize="@dimen/ch_text_size_label" />

                <TextView
                    android:id="@+id/trackingEtaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/ch_primary"
                    android:textSize="@dimen/ch_text_size_title"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/trackingGpsStatusValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/tracking_gps_searching"
                    android:textColor="@color/ch_on_surface_variant"
                    android:textSize="@dimen/ch_text_size_caption" />

                <TextView
                    android:id="@+id/trackingSyncStatusValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="@string/tracking_sync_paused"
                    android:textColor="@color/ch_on_surface_variant"
                    android:textSize="@dimen/ch_text_size_caption" />
            </LinearLayout>

            <!-- Distance remaining -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/tracking_map_distance_remaining_label"
                    android:textColor="@color/ch_on_surface_variant"
                    android:textSize="@dimen/ch_text_size_label" />

                <TextView
                    android:id="@+id/trackingDistanceRemainingValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/ch_on_surface"
                    android:textSize="@dimen/ch_text_size_body_large"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_xs"
                android:background="@color/ch_outline" />

            <!-- Stats grid: 2x2 row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Time worked -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackingTimeWorkedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="@color/ch_on_surface"
                        android:textSize="@dimen/ch_text_size_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_time_worked_label"
                        android:textColor="@color/ch_on_surface_variant"
                        android:textSize="@dimen/ch_text_size_caption" />
                </LinearLayout>

                <!-- Distance covered -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackingDistanceCoveredValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km"
                        android:textColor="@color/ch_on_surface"
                        android:textSize="@dimen/ch_text_size_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_distance_covered_label"
                        android:textColor="@color/ch_on_surface_variant"
                        android:textSize="@dimen/ch_text_size_caption" />
                </LinearLayout>

                <!-- Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackingSpeedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 km/h"
                        android:textColor="@color/ch_on_surface"
                        android:textSize="@dimen/ch_text_size_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_speed_label"
                        android:textColor="@color/ch_on_surface_variant"
                        android:textSize="@dimen/ch_text_size_caption" />
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_xs"
                android:background="@color/ch_outline" />

            <!-- Pause stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Time paused -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackingTimePausedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/ch_warning"
                        android:textSize="@dimen/ch_text_size_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_time_paused_label"
                        android:textColor="@color/ch_on_surface_variant"
                        android:textSize="@dimen/ch_text_size_caption" />
                </LinearLayout>

                <!-- Pause count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackingPauseCountValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/ch_on_surface"
                        android:textSize="@dimen/ch_text_size_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_pause_count_label"
                        android:textColor="@color/ch_on_surface_variant"
                        android:textSize="@dimen/ch_text_size_caption" />
                </LinearLayout>

                <!-- Total time -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackingTimeTotalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="@color/ch_on_surface"
                        android:textSize="@dimen/ch_text_size_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_time_total_label"
                        android:textColor="@color/ch_on_surface_variant"
                        android:textSize="@dimen/ch_text_size_caption" />
                </LinearLayout>
            </LinearLayout>

            <!-- Acciones operativas del porte -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/trackingReportIncidentButton"
                style="@style/Widget.ApiCargoHub.Button.Primary"
                android:backgroundTint="@color/ch_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:contentDescription="@string/tracking_report_incident_content_description"
                android:text="@string/trip_report_incident_action"
                android:textAllCaps="false"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trackingConfirmPickupButton"
                style="@style/Widget.ApiCargoHub.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:backgroundTint="@color/ch_accent_primary"
                android:contentDescription="@string/tracking_confirm_pickup_content_description"
                android:text="@string/tracking_confirm_pickup_action"
                android:textAllCaps="false"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trackingStopButton"
                style="@style/Widget.ApiCargoHub.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:backgroundTint="@color/ch_success"
                android:contentDescription="@string/tracking_finalize_content_description"
                android:text="@string/tracking_finalize_action"
                android:textAllCaps="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>
