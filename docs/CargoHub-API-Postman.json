{
  "info": {
    "name": "CargoHub API",
    "description": "Colección de requests para probar la API de CargoHub - Sistema de gestión logística",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticación",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', jsonData.accessToken);",
                  "    pm.collectionVariables.set('userId', jsonData.id);",
                  "    pm.collectionVariables.set('userRole', jsonData.rol);",
                  "    if (jsonData.conductorId) pm.collectionVariables.set('conductorId', jsonData.conductorId);",
                  "    if (jsonData.clienteId) pm.collectionVariables.set('clienteId', jsonData.clienteId);",
                  "}",
                  "",
                  "pm.test('Login exitoso', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Token recibido', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('accessToken');",
                  "    pm.expect(jsonData).to.have.property('rol');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formurlencoded",
              "formurlencoded": [
                {
                  "key": "email",
                  "value": "admin@cargohub.com",
                  "description": "Email del usuario"
                },
                {
                  "key": "password",
                  "value": "Admin123!",
                  "description": "Contraseña"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login con email y password. Retorna accessToken JWT que se guarda automáticamente en la variable de colección."
          }
        },
        {
          "name": "2. Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formurlencoded",
              "formurlencoded": [
                {
                  "key": "email",
                  "value": "nuevo@conductor.com",
                  "description": "Email del usuario"
                },
                {
                  "key": "password",
                  "value": "Password123!",
                  "description": "Contraseña"
                },
                {
                  "key": "rol",
                  "value": "CONDUCTOR",
                  "description": "Rol: SUPERADMIN, ADMIN, CONDUCTOR, CLIENTE"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Registro de nuevo usuario. Roles disponibles: SUPERADMIN, ADMIN, CONDUCTOR, CLIENTE"
          }
        }
      ]
